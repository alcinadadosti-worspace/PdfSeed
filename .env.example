# ============================================================
# FRONTEND (Vite)
# ============================================================
# URL do backend (servidor que se comunica com o Slack)
# Em desenvolvimento: http://localhost:3001
# Em producao (mesmo servidor servindo o site): deixe em branco
VITE_API_URL=http://localhost:3001

# ============================================================
# BACKEND (servidor Node/Express) - defina no Render tambem
# ============================================================
# Token do bot do Slack (escopos: chat:write, files:write, im:write, users:read)
SLACK_BOT_TOKEN=xoxb-xxxxxxxx

# Porta do servidor (o Render define automaticamente)
PORT=3001

# URL do frontend, para o CORS (em producao a URL do seu site no Render)
FRONTEND_URL=http://localhost:5173

# ------------------------------------------------------------
# Cadastro de funcionarios pela app (GitHub como armazenamento)
# ------------------------------------------------------------
# Token do GitHub (fine-grained) com permissao de Contents: Read and write
# no repositorio abaixo. Sem ele, o cadastro pela app fica desabilitado.
GITHUB_TOKEN=github_pat_xxxxxxxx

# Repositorio onde o arquivo de cadastros fica salvo (padrao ja aponta pro seu)
GITHUB_REPO=alcinadadosti-worspace/PdfSeed
GITHUB_BRANCH=main
GITHUB_FILE_PATH=data/employees.json

# (Opcional) Senha para proteger o cadastro/remocao de funcionarios.
# Se definida, o formulario exige essa senha. Se vazia, fica liberado.
ADMIN_PASSWORD=
